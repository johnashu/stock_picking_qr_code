<?xml version="1.0" encoding="utf-8"?>
<!--
    Stock Picking QR Codes

    Two reports are patched:

      A. stock.report_picking (Picking Operations)
         Each existing barcode widget is converted to QR symbology in
         place. 

      B. stock.report_return_slip (Return Slip)
         Both existing barcode widgets on the return slip are converted
         to QR in place:
           - o.name
           - 'OBTRETU'

    Each QR conversion lives in its own <template> record so that one
    target can be deactivated independently if a future module mutates
    that section of the upstream report.

    KNOWN CONFLICTS:
      * stock_picking_totals_report
        If another module rewrites the `move`/`line` rows in
        `stock.report_picking`, xpath anchors for per-line lot/serial
        and product barcode conversions may no longer exist.
        If you install both modules together and encounter xpath errors,
        deactivate the two views listed below in Settings -> Technical
        -> Views:
            - stock_report_picking_qr_lot
            - stock_report_picking_qr_product

    Adjust width / height / img_style on each t-options to resize the
    QR codes.
-->
<odoo>

    <!--
        ============================================================
        A. stock.report_picking (Picking Operations)
        ============================================================
    -->

    <!-- A1. Document (picking name) barcode -> QR -->
    <template id="stock_report_picking_qr_document"
        inherit_id="stock.report_picking">
        <xpath expr="//div[@t-field='o.name'][contains(@t-options, 'barcode')]"
            position="attributes">
            <attribute name="t-options">{'widget': 'barcode', 'symbology': 'QR', 'width': 200,
                'height': 200, 'img_style': 'width:80px;height:80px;'}</attribute>
        </xpath>
    </template>

    <!-- A2. Lot / Serial Number barcode -> QR
         Deactivate this view if stock_picking_totals_report is installed. -->
    <template id="stock_report_picking_qr_lot"
        inherit_id="stock.report_picking">
        <xpath
            expr="//span[@t-if='line.lot_id or line.lot_name'][@t-out='line.lot_id.name or line.lot_name'][contains(@t-options, 'barcode')]"
            position="attributes">
            <attribute name="t-options">{'widget': 'barcode', 'symbology': 'QR',
                'width': 200,
                'height': 200, 'img_style': 'width:60px;height:60px;'}</attribute>
        </xpath>
        <xpath
            expr="//span[@t-if='line.lot_id or line.lot_name'][@t-out='line.lot_id.name or line.lot_name'][contains(@t-options, 'barcode')]"
            position="after">
            <div class="text-center mt-1">
                <small t-esc="line.lot_id.name or line.lot_name" />
            </div>
        </xpath>
    </template>

    <!-- A3. Product barcode -> QR
         Deactivate this view if stock_picking_totals_report is installed. -->
    <template id="stock_report_picking_qr_product"
        inherit_id="stock.report_picking">
        <xpath expr="//div[@t-field='move.product_id.barcode'][contains(@t-options, 'barcode')]"
            position="attributes">
            <attribute name="t-options">{'widget': 'barcode', 'symbology': 'QR',
                'width': 200,
                'height': 200, 'img_style': 'width:60px;height:60px;'}</attribute>
        </xpath>
        <xpath expr="//div[@t-field='move.product_id.barcode'][contains(@t-options, 'barcode')]"
            position="after">
            <div class="text-center mt-1">
                <small t-esc="move.product_id.barcode" />
            </div>
        </xpath>
    </template>

    <!-- A4. Package barcode -> QR -->
    <template id="stock_report_picking_qr_package"
        inherit_id="stock.report_picking">
        <xpath
            expr="//td[@name='td_pk_barcode']//div[@t-field='package.name'][contains(@t-options, 'barcode')]"
            position="attributes">
            <attribute name="t-options">{'widget': 'barcode', 'symbology': 'QR',
                'width': 200,
                'height': 200, 'img_style': 'width:60px;height:60px;'}</attribute>
        </xpath>
        <xpath
            expr="//td[@name='td_pk_barcode']//div[@t-field='package.name'][contains(@t-options, 'barcode')]"
            position="after">
            <div class="text-center mt-1">
                <small t-esc="package.name" />
            </div>
        </xpath>
    </template>

    <!--
        ============================================================
        B. stock.report_return_slip (Return Slip)
        ============================================================
        The return slip includes two barcode widgets directly in
        stock.report_return_slip, so both can be swapped via
        position="attributes".
    -->

    <!-- B1. Return slip o.name barcode -> QR -->
    <template id="stock_report_return_slip_qr_name"
        inherit_id="stock.report_return_slip">
        <xpath expr="//span[@t-field='o.name'][contains(@t-options, 'barcode')]"
            position="attributes">
            <attribute name="t-options">{'widget': 'barcode', 'symbology': 'QR',
                'width': 200, 'height': 200, 'img_style': 'width:100px;height:100px;'}</attribute>
        </xpath>
        <xpath
            expr="//div[span[@t-field='o.name'][contains(@t-options, 'barcode')]]/span[@t-out='o.name']"
            position="attributes">
            <attribute name="class">d-block mt-1 text-center</attribute>
        </xpath>

        <!-- B2. Return slip OBTRETU barcode -> QR -->

        <xpath expr="//span[@t-out=&quot;'OBTRETU'&quot;][contains(@t-options, 'barcode')]"
            position="attributes">
            <attribute name="t-options">{'widget': 'barcode', 'symbology': 'QR',
                'width': 200, 'height': 200, 'img_style': 'width:100px;height:100px;'}</attribute>
        </xpath>
        <xpath expr="//div[@style='margin-top:200px;']/span[not(@t-options)]"
            position="attributes">
            <attribute name="class">d-block mt-1 text-center</attribute>
        </xpath>
    </template>

</odoo>