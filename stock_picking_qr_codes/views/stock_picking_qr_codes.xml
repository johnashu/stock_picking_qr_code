<?xml version="1.0" encoding="utf-8"?>
<!--
    Stock Picking report: replace all barcodes with QR codes.
    Inherits stock.report_picking.

    Each barcode is patched in its own <template> record so that the four
    QR conversions are independent. If a future module removes one of the
    xpath targets, only the affected template needs to be deactivated
    manually (Settings -> Technical -> Views), the others keep working.

    KNOWN CONFLICTS:
      * stock_picking_totals_report
        Replaces the per-line <tr t-as='ml'> row, which removes the xpath
        targets for #2 (Lot / Serial) and #3 (Product). If you install
        both modules together, deactivate the two views listed below in
        Settings -> Technical -> Views, otherwise the picking report will
        fail to render:
            - stock_report_picking_qr_lot
            - stock_report_picking_qr_product

    Adjust width / height / img_style on each t-options to resize the QR codes.
-->
<odoo>

    <!-- 1. Document (picking name) barcode -> QR -->
    <template id="stock_report_picking_qr_document"
        inherit_id="stock.report_picking">
        <xpath expr="//div[@t-field='o.name'][contains(@t-options, 'barcode')]"
            position="attributes">
            <attribute name="t-options">{'widget': 'barcode', 'symbology': 'QR', 'width': 200,
                'height': 200, 'img_style': 'width:80px;height:80px;'}</attribute>
        </xpath>
    </template>

    <!-- 2. Lot / Serial Number barcode -> QR
         Deactivate this view if stock_picking_totals_report is installed. -->
    <template id="stock_report_picking_qr_lot"
        inherit_id="stock.report_picking">
        <xpath expr="//span[@t-esc='ml.lot_id.name or ml.lot_name']"
            position="attributes">
            <attribute name="t-options">{'widget': 'barcode', 'symbology': 'QR',
                'width': 200,
                'height': 200, 'img_style': 'width:60px;height:60px;'}</attribute>
        </xpath>
        <xpath expr="//span[@t-esc='ml.lot_id.name or ml.lot_name']"
            position="after">
            <div class="text-center mt-1">
                <small t-esc="ml.lot_id.name or ml.lot_name" />
            </div>
        </xpath>
    </template>

    <!-- 3. Product barcode -> QR
         Deactivate this view if stock_picking_totals_report is installed. -->
    <template id="stock_report_picking_qr_product"
        inherit_id="stock.report_picking">
        <xpath expr="//div[@t-field='ml.product_id.barcode']"
            position="attributes">
            <attribute name="t-options">{'widget': 'barcode', 'symbology': 'QR',
                'width': 200,
                'height': 200, 'img_style': 'width:60px;height:60px;'}</attribute>
        </xpath>
        <xpath expr="//div[@t-field='ml.product_id.barcode']"
            position="after">
            <div class="text-center mt-1">
                <small t-esc="ml.product_id.barcode" />
            </div>
        </xpath>
    </template>

    <!-- 4. Package barcode -> QR -->
    <template id="stock_report_picking_qr_package"
        inherit_id="stock.report_picking">
        <xpath expr="//div[@t-field='package.package_id.name'][contains(@t-options, 'barcode')]"
            position="attributes">
            <attribute name="t-options">{'widget': 'barcode', 'symbology': 'QR',
                'width': 200,
                'height': 200, 'img_style': 'width:60px;height:60px;'}</attribute>
        </xpath>
        <xpath expr="//div[@t-field='package.package_id.name'][contains(@t-options, 'barcode')]"
            position="after">
            <div class="text-center mt-1">
                <small t-esc="package.package_id.name" />
            </div>
        </xpath>
    </template>

</odoo>